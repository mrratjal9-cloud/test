	-- ==========================================
	-- NOCLIP (UPGRADED - lebih kuat menembus tembok)
	-- Memperbaiki masalah:
	--  1) Part baru (accessory/tools) yang spawn saat runtime
	--  2) CollisionGroup khusus yang dipakai game
	--  3) Anti-cheat client yang re-enable CanCollide
	-- ==========================================
	local noclip = Config.Noclip
	local noclipConn
	local descAddedConn
	local charAddedConn

	local function noclipChar(char)
		if not char then return end
		for _, v in ipairs(char:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
				-- pindah ke collision group default agar tidak terkena rule custom game
				pcall(function() v.CollisionGroup = "Default" end)
				pcall(function() v.CollisionGroupId = 0 end)
			end
		end
	end

	local function bindNoclip()
		-- Disconnect lama dulu agar tidak dobel
		if noclipConn then noclipConn:Disconnect() end
		if descAddedConn then descAddedConn:Disconnect() end
		if charAddedConn then charAddedConn:Disconnect() end

		-- Loop tiap physics step (paling cepat sebelum collision dihitung)
		noclipConn = RunService.Stepped:Connect(function()
			if noclip then
				noclipChar(Lr.Character)
			end
		end)

		-- Tangani part baru yang dimasukkan ke karakter (accessory/tool)
		local function hookChar(char)
			if descAddedConn then descAddedConn:Disconnect() end
			descAddedConn = char.DescendantAdded:Connect(function(d)
				if noclip and d:IsA("BasePart") then
					task.defer(function()
						d.CanCollide = false
						pcall(function() d.CollisionGroup = "Default" end)
					end)
				end
			end)
		end

		if Lr.Character then hookChar(Lr.Character) end
		charAddedConn = Lr.CharacterAdded:Connect(function(char)
			task.wait(0.2)
			hookChar(char)
		end)
	end

	createToggle("Noclip", Config.Noclip, function(state)
		noclip = state
		if state then
			bindNoclip()
		end
	end)

	-- pre-bind kalau noclip default-nya ON
	if noclip then bindNoclip() end

