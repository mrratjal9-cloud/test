	-- ==========================================
	-- BASIC ANIMATION & BASIC MOVE
	-- Hapus jitter / getaran animasi custom dari game,
	-- gantikan dengan animasi default Roblox yang halus.
	-- ==========================================
	local basicAnimEnabled = false
	local basicAnimLoop
	local savedAnimateScript -- backup script Animate yang aslinya

	-- Animation ID default Roblox (R15) - sederhana, halus, tanpa getaran
	-- NOTE: jangan pakai "://" literal di source code, karena beberapa
	-- executor mobile/web-loader meng-strip C-style comment "//" dan
	-- merusak string. Kita bangun pakai string.char(47,47) = "//".
	local _SL = string.char(47, 47) -- "//"
	local function _aid(num) return "rbxassetid:" .. _SL .. tostring(num) end

	local R15_DEFAULT_ANIMS = {
		idle    = _aid(507766388),
		walk    = _aid(507777826),
		run     = _aid(507767714),
		jump    = _aid(507765000),
		fall    = _aid(507767968),
		climb   = _aid(507765644),
		sit     = _aid(507768133),
	}

	local function applyBasicAnim(char)
		if not char then return end
		local hum = char:FindFirstChildOfClass("Humanoid")
		if not hum then return end

		-- Hentikan dulu semua track yang berjalan
		for _, t in ipairs(hum:GetPlayingAnimationTracks()) do
			pcall(function() t:Stop(0) end)
		end

		-- Disable script Animate bawaan game (yang biasanya bikin getaran)
		local animate = char:FindFirstChild("Animate")
		if animate and animate:IsA("LocalScript") then
			savedAnimateScript = animate
			animate.Disabled = true
		end

		-- Reset CameraOffset agar kamera tidak bergoyang/jitter
		hum.CameraOffset = Vector3.new(0, 0, 0)
		hum.AutoRotate = true

		-- Pasang Animator yang clean
		local animator = hum:FindFirstChildOfClass("Animator") or Instance.new("Animator", hum)

		-- Buat StringValue untuk override animation IDs (cara yang dipakai R15 default)
		local function setAnim(folderName, animId)
			local folder = char:FindFirstChild(folderName)
			if not folder then
				folder = Instance.new("StringValue")
				folder.Name = folderName
				folder.Parent = char
			end
			-- Hapus semua child Animation lama
			for _, c in ipairs(folder:GetChildren()) do c:Destroy() end
			local anim = Instance.new("Animation")
			anim.AnimationId = animId
			anim.Parent = folder
		end

		setAnim("idle",  R15_DEFAULT_ANIMS.idle)
		setAnim("walk",  R15_DEFAULT_ANIMS.walk)
		setAnim("run",   R15_DEFAULT_ANIMS.run)
		setAnim("jump",  R15_DEFAULT_ANIMS.jump)
		setAnim("fall",  R15_DEFAULT_ANIMS.fall)
		setAnim("climb", R15_DEFAULT_ANIMS.climb)
		setAnim("sit",   R15_DEFAULT_ANIMS.sit)

		-- Mainkan idle dulu agar transisi halus
		pcall(function()
			local idleAnim = Instance.new("Animation")
			idleAnim.AnimationId = R15_DEFAULT_ANIMS.idle
			local track = animator:LoadAnimation(idleAnim)
			track:Play(0.1)
		end)
	end

	local function restoreAnim(char)
		if not char then return end
		if savedAnimateScript and savedAnimateScript.Parent then
			savedAnimateScript.Disabled = false
		end
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hum then hum.CameraOffset = Vector3.new(0, 0, 0) end
	end

	createToggle("Basic Animation & Move", Config.Basic_Animation, function(state)
		basicAnimEnabled = state
		if state then
			applyBasicAnim(Lr.Character)
			-- pastikan setiap respawn animasi tetap di-apply
			if basicAnimLoop then basicAnimLoop:Disconnect() end
			basicAnimLoop = Lr.CharacterAdded:Connect(function(char)
				task.wait(0.5) -- tunggu game pasang script Animate-nya
				if basicAnimEnabled then applyBasicAnim(char) end
			end)
		else
			if basicAnimLoop then basicAnimLoop:Disconnect() basicAnimLoop = nil end
			restoreAnim(Lr.Character)
		end
	end)

	-- ==========================================
	-- MOUSE UNLOCK (anti shift-lock paksa dari developer)
	-- Force MouseBehavior = Default & MouseIconEnabled = true
	-- Juga override DevEnableMouseLock setiap frame
	-- ==========================================
	local mouseUnlockEnabled = false
	local mouseConn

	createToggle("Mouse Unlock (Anti ShiftLock)", Config.Mouse_Unlock, function(state)
		mouseUnlockEnabled = state
		if state then
			-- matikan shift-lock dari level player
			pcall(function() Lr.DevEnableMouseLock = false end)

			if mouseConn then mouseConn:Disconnect() end
			mouseConn = RunService.RenderStepped:Connect(function()
				if not mouseUnlockEnabled then return end
				-- Paksa mouse bebas tiap frame (override script developer)
				if UserInputService.MouseBehavior ~= Enum.MouseBehavior.Default then
					UserInputService.MouseBehavior = Enum.MouseBehavior.Default
				end
				if not UserInputService.MouseIconEnabled then
					UserInputService.MouseIconEnabled = true
				end
				-- Override shift-lock di kamera kalau ada
				pcall(function()
					if Lr.DevEnableMouseLock then
						Lr.DevEnableMouseLock = false
					end
				end)
			end)
		else
			if mouseConn then mouseConn:Disconnect() mouseConn = nil end
		end
	end)

	if mouseUnlockEnabled then
		-- jalanin sekali kalau ON di config
	end
end

